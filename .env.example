# ─── Database ───────────────────────────────────────────
# SQLite (local development)
DATABASE_URL="file:./dev.db"

# ─── Admin Authentication ───────────────────────────────
# Credentials for the /admin panel (HTTP Basic Auth)
ADMIN_USER="admin"
ADMIN_PASSWORD="your-secure-password"

# ─── Vercel Blob Storage ────────────────────────────────
# Required for image uploads (cover, gallery, editor).
# Get your token at: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=""

# ─── Webhooks ───────────────────────────────────────────
# Secret token for Zapier/Make.com → Evernote webhook
EVERNOTE_WEBHOOK_SECRET="your-webhook-secret"
