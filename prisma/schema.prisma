generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Article {
  id           String   @id @default(cuid())
  title        String
  content      String
  excerpt      String?
  coverImage   String?
  bgImage      String?
  authorName   String?
  authorAvatar String?
  tags         String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())
}
