# Postgres (Vercel Postgres)
POSTGRES_PRISMA_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:port/dbname"

# ─── Admin Authentication ───────────────────────────────
# Credentials for the /admin panel (HTTP Basic Auth)
ADMIN_USER="admin"
ADMIN_PASSWORD="your-secure-password"

# ─── Vercel Blob Storage ────────────────────────────────
# Required for image uploads (cover, gallery, editor).
# Get your token at: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=""

# ─── Webhooks ───────────────────────────────────────────
# Secret token for Zapier/Make.com → Evernote webhook
EVERNOTE_WEBHOOK_SECRET="your-webhook-secret"
